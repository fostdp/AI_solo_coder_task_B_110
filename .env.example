# ============================================================
# 古代星表系统环境变量配置模板
# 使用前请复制为 .env 并修改其中的敏感信息
# ============================================================

# ------------------------------------------------------------
# PostgreSQL / PostGIS 数据库配置
# ------------------------------------------------------------

# Postgres 超级用户密码 (请修改为强密码)
POSTGRES_PASSWORD=change_me_to_a_strong_password

# 数据库连接信息
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ancient_star
DB_USER=star_admin
DB_PASSWORD=change_me_to_a_strong_password

# 完整数据库连接 URL (postgres://user:password@host:port/dbname)
DATABASE_URL=postgres://star_admin:change_me_to_a_strong_password@localhost:5432/ancient_star

# ------------------------------------------------------------
# API 服务配置
# ------------------------------------------------------------

# API 监听地址
API_HOST=0.0.0.0
API_PORT=8080

# Rust 日志级别: error, warn, info, debug, trace
RUST_LOG=info

# 配置文件目录 (容器内路径，通常无需修改)
CONFIG_DIR=/app/config

# ------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------

# 数据库连接池最大连接数
MAX_DB_CONN=16
